{
  "name": "task-management-api",
  "version": "1.0.0",
  "description": "A simple Task Management REST API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "test": "jest --forceExit --detectOpenHandles",
